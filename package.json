{
  "name": "qury-editor",
  "version": "0.7.0",
  "description": "Desktop SQL editor built with Electron.",
  "author": {
    "name": "Jonas Guedes",
    "email": "jonaskof@gmail.com"
  },
  "homepage": "https://jonasguedes.com",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:app": "npm run build && node scripts/copy-main-drivers.cjs",
    "dist": "npm run build:app && npx electron-builder",
    "build:mac:arm64": "npm run build:app && npx electron-builder --mac dmg --arm64 --publish never",
    "build:win:x64": "npm run build:app && npx electron-builder --win zip --x64 --publish never",
    "build:linux:deb": "npm run build:app && npx electron-builder --linux deb --x64 --publish never",
    "build:linux:deb:arm64": "npm run build:app && npx electron-builder --linux deb --arm64 --publish never",
    "rebuild:native": "node scripts/rebuild-native.cjs",
    "postinstall": "npm run rebuild:native"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.14",
    "@fontsource/fira-code": "^5.2.7",
    "@lezer/highlight": "^1.2.3",
    "better-sqlite3": "^12.6.2",
    "bootstrap-icons": "^1.13.1",
    "codemirror": "^6.0.2",
    "mysql2": "^3.17.0",
    "pg": "^8.18.0",
    "sql-formatter": "^15.7.0",
    "sql.js": "^1.13.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "archiver": "^7.0.1",
    "electron": "^40.4.0",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.qury.editor",
    "productName": "Qury Editor",
    "npmRebuild": true,
    "afterPack": "scripts/after-pack.cjs",
    "afterAllArtifactBuild": "scripts/after-all-artifacts.cjs",
    "icon": "public/icon.png",
    "asar": true,
    "directories": {
      "output": "dist/release",
      "buildResources": "public"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/*.map"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "mac": {
      "icon": "public/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "qury-mac.dmg"
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "qury-windows.zip"
    },
    "linux": {
      "icon": "public/icons",
      "maintainer": "Jonas Guedes <jonaskof@gmail.com>",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "qury-linux.deb"
    }
  }
}
